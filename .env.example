# Este demo es autocontenido (clone & run): no necesitas configurar nada para
# levantarlo. Los valores reales viven en docker-compose.yml y en backend/.env,
# y son DUMMIES de demostracion (no son secretos de produccion).
#
# Este archivo queda como referencia de las variables que tocarias si adaptaras
# el proyecto a un entorno real (donde SI debes usar secretos propios).

# Backend (Symfony)
# APP_ENV=dev
# APP_SECRET=cambialo_en_produccion
# DATABASE_URL="mysql://app:app@db:3306/app?serverVersion=8.0&charset=utf8mb4"

# Base (MySQL) — definidas en docker-compose.yml
# MYSQL_DATABASE=app
# MYSQL_USER=app
# MYSQL_PASSWORD=app
# MYSQL_ROOT_PASSWORD=root
